APP_NAME="BBSC Trainer Dashboard"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.laravel.cloud

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database (MySQL) ──────────────────────────────────────────────────────
# Laravel Cloud injects these automatically. For local dev, fill in manually.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bbsc_trainers
DB_USERNAME=root
DB_PASSWORD=

# ─── Session / Cache / Queue ───────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database
CACHE_STORE=database

# ─── File Storage ──────────────────────────────────────────────────────────
# Set to 's3' in production (Laravel Cloud provides S3-compatible storage).
# Use 'local' for local development only.
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Mail ──────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@bbsc.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Twilio SMS ────────────────────────────────────────────────────────────
# Required for SMS assignment notifications and trainer reply webhook.
# Sign up at https://twilio.com, buy a phone number, register a campaign.
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ─── Admin Seeder ──────────────────────────────────────────────────────────
# Used by DatabaseSeeder to create the default admin account on first migrate.
ADMIN_EMAIL=admin@bbsc.com
ADMIN_PASSWORD=password

# ─── Vite ──────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
